# Twitch (optional)
ENABLE_TWITCH=false # Set to false to disable
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TWITCH_USER_LOGIN=your_247_twitch_channel
# Leave empty, the program handles this automatically
BROADCASTER_ID=
TWITCH_REDIRECT_URI=http://localhost:8080/callback

# Kick (optional)
ENABLE_KICK=false # Set to false to disable
KICK_CLIENT_ID=your_kick_client_id
KICK_CLIENT_SECRET=your_kick_client_secret
# Leave empty — auto-resolved during first OAuth login
KICK_CHANNEL_ID=
KICK_REDIRECT_URI=http://localhost:8080/callback

# Live Detection (optional)
# When a target streamer is set, the system pauses the 24/7 stream while they are live.
# Set one or both. If both are set, either being live triggers the pause.
# Leave empty to disable live detection (ideal for pure 24/7 music/ambient/etc streams).
#
# Twitch live detection uses EventSub WebSocket for near-instant pause/unpause,
# with HTTP polling as a safety-net fallback. Kick uses HTTP polling only.
TARGET_TWITCH_STREAMER=
TARGET_KICK_STREAMER=

# Unpause Mode (optional — Twitch only)
# "offline" (default) = unpause when stream.offline fires (or offline poll as fallback).
# "raid" = also unpause immediately when the streamer raids out, whichever fires first.
# Useful when the streamer often forgets to end live after raiding, which delays unpause.
# Requires TWITCH_CLIENT_ID, TWITCH_CLIENT_SECRET, and a stored Twitch user token
# (created automatically during the first Twitch platform auth flow).
UNPAUSE_MODE=offline

# OBS
OBS_HOST=
OBS_PORT=4455
OBS_PASSWORD=
SCENE_PAUSE=OSR Pause screen
SCENE_STREAM=OSR Stream
SCENE_ROTATION_SCREEN=OSR Rotation screen
VLC_SOURCE_NAME=OSR Playlist

# Optional path to OBS executable for auto-relaunch on freeze. Required if not in system PATH.
OBS_PATH=

# Video Folders (optional — defaults to content/live/ and content/pending/ next to the exe)
# Only set these if you want custom paths.
# VIDEO_FOLDER=
# NEXT_ROTATION_FOLDER=

# Discord
DISCORD_WEBHOOK_URL=

# Web Dashboard (optional)
# Connect this OSR instance to the web dashboard for remote monitoring & control.
# Get the API key from the Team page after creating an instance.
WEB_DASHBOARD_URL=
WEB_DASHBOARD_API_KEY=